generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COORDINATOR
  MONITOR
  STUDENT
}

enum QueueStatus {
  WAITING
  CALLED
  IN_SERVICE
  FINISHED
  CANCELLED
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  monitorias        Monitoria[]
  queueEntries      QueueEntry[]
  monitorSessions   MonitorSession[]
  AttendanceHistory AttendanceHistory[]

  @@index([slug])
}

model User {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  email         String?  @unique
  username      String   @unique
  passwordHash  String
  role          UserRole
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  studentQueueEntries QueueEntry[]        @relation("StudentQueueEntries")
  monitorSessions     MonitorSession[]    @relation("MonitorSessionsByUser")
  subjectAssignments  MonitorSubject[]
  monitorias          Monitoria[]         @relation("MonitorMonitorias")
  monitorHistory      AttendanceHistory[] @relation("MonitorHistory")

  @@index([institutionId])
  @@index([institutionId, role])
  @@index([username])
}

model Monitoria {
  id            String   @id @default(cuid())
  institutionId String
  monitorId     String
  subjectId     String
  title         String
  description   String?
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution     Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  monitor         User             @relation("MonitorMonitorias", fields: [monitorId], references: [id], onDelete: Cascade)
  subject         Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  queueEntries    QueueEntry[]
  monitorSessions MonitorSession[]

  @@unique([institutionId, monitorId, subjectId])
}

model Subject {
  id         String      @id @default(cuid())
  name       String      @unique
  monitorias Monitoria[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  modules            Module[]
  queueEntries       QueueEntry[]
  monitorAssignments MonitorSubject[]

  @@index([name])
}

model Module {
  id          String   @id @default(cuid())
  subjectId   String
  code        String
  title       String
  front       String?
  book        String?
  sourceSheet String?
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  topics          Topic[]
  queueEntries    QueueEntry[]
  queueEntryLinks QueueEntryModule[]

  @@unique([subjectId, code], name: "subjectId_code")
  @@index([subjectId])
  @@index([subjectId, sortOrder])
}

model Topic {
  id        String   @id @default(cuid())
  moduleId  String
  name      String
  sortOrder Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([moduleId, sortOrder])
}

model MonitorSubject {
  id        String   @id @default(cuid())
  monitorId String
  subjectId String
  createdAt DateTime @default(now())

  monitor User    @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([monitorId, subjectId])
  @@index([monitorId])
  @@index([subjectId])
}

model QueueEntry {
  id              String      @id @default(cuid())
  institutionId   String
  monitoriaId     String
  studentId       String
  subjectId       String?
  moduleId        String?
  status          QueueStatus
  notes           String?
  createdAt       DateTime    @default(now())
  calledAt        DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  canceledAt      DateTime?
  requeuedAt      DateTime?
  updatedAt       DateTime    @updatedAt
  rating          Int?
  feedbackComment String?
  feedbackAt      DateTime?

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  monitoria   Monitoria   @relation(fields: [monitoriaId], references: [id], onDelete: Cascade)
  student     User        @relation("StudentQueueEntries", fields: [studentId], references: [id], onDelete: Cascade)
  subject     Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  module      Module?     @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  selectedModules QueueEntryModule[]

  @@index([institutionId])
  @@index([monitoriaId])
  @@index([studentId])
  @@index([subjectId])
  @@index([moduleId])
  @@index([status])
  @@index([institutionId, status])
  @@index([institutionId, monitoriaId, status])
}

model QueueEntryModule {
  id           String   @id @default(cuid())
  queueEntryId String
  moduleId     String
  createdAt    DateTime @default(now())

  queueEntry QueueEntry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
  module     Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([queueEntryId, moduleId])
  @@index([queueEntryId])
  @@index([moduleId])
}

model MonitorSession {
  id            String    @id @default(cuid())
  monitorId     String
  institutionId String
  monitoriaId   String
  socketId      String    @unique
  isOnline      Boolean   @default(true)
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  lastSeenAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  monitor     User        @relation("MonitorSessionsByUser", fields: [monitorId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  monitoria   Monitoria   @relation(fields: [monitoriaId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([institutionId])
  @@index([monitoriaId])
  @@index([isOnline])
  @@index([monitorId, isOnline])
}

model AttendanceHistory {
  id             String    @id @default(cuid())
  institutionId  String
  monitorId      String
  studentId      String?
  queueEntryId   String?
  subjectId      String?
  studentName    String
  studentPhone   String?
  subjectName    String?
  moduleNames    String[]
  statusFinal    String
  enteredQueueAt DateTime?
  calledAt       DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  waitSeconds    Int?
  serviceSeconds Int?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
  monitor     User        @relation("MonitorHistory", fields: [monitorId], references: [id])
}
