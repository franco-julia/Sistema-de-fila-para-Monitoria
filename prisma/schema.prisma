generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  monitorias      Monitoria[]
  queueEntries    QueueEntry[]
  MonitorSessions MonitorSession[]
  Attendance      Attendance[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole
  institutionId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  queueEntries    QueueEntry[]
  monitorSessions MonitorSession[] @relation("MonitorSessionsByUser")
  MonitorSubject  MonitorSubject[]
  Attendance      Attendance[]

  @@index([institutionId])
  @@index([institutionId, role])
}

enum UserRole {
  ADMIN
  MONITOR
  ALUNO
}

model Monitoria {
  id            String   @id @default(cuid())
  title         String
  description   String?
  active        Boolean  @default(true)
  institutionId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution     Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  queueEntries    QueueEntry[]
  monitorSessions MonitorSession[]

  @@index([institutionId])
  @@index([institutionId, active])
}

model MonitorSubject {
  id        String @id @default(cuid())
  monitorId String
  subject   String

  monitor User @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@unique([monitorId, subject])
}

model QueueEntry {
  id            String      @id @default(cuid())
  institutionId String
  monitoriaId   String
  studentId     String
  status        QueueStatus @default(WAITING)
  notes         String?
  createdAt     DateTime    @default(now())
  calledAt      DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?
  canceledAt    DateTime?
  updatedAt     DateTime    @updatedAt

  institution      Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  monitoria        Monitoria          @relation(fields: [monitoriaId], references: [id], onDelete: Cascade)
  student          User               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  QueueEntryModule QueueEntryModule[]

  @@index([institutionId])
  @@index([monitoriaId])
  @@index([studentId])
  @@index([institutionId, monitoriaId, status])
  @@index([institutionId, monitoriaId, createdAt])
}

enum QueueStatus {
  WAITING
  CALLED
  IN_SERVICE
  FINISHED
  NO_SHOW
  CANCELLED
}

model QueueEntryModule {
  id           String  @id @default(cuid())
  queueEntryId String
  code         String?
  name         String

  queueEntry QueueEntry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
}

model Attendance {
  id                String   @id @default(cuid())
  institutionId     String
  monitorId         String
  queueEntryId      String?
  externalStudentId String?
  studentName       String
  studentPhone      String
  studentClass      String?
  subject           String
  startedAt         DateTime
  endedAt           DateTime
  durationMinutes   Int
  createdAt         DateTime @default(now())

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  monitor     User               @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  modules     AttendanceModule[]
  feedback    Feedback?

  @@index([institutionId, createdAt])
  @@index([monitorId, createdAt])
}

model AttendanceModule {
  id           String  @id @default(cuid())
  attendanceId String
  code         String?
  name         String

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model Feedback {
  id           String   @id @default(cuid())
  attendanceId String   @unique
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

enum MonitorStatus {
  AVAILABLE
  PAUSED
}

model MonitorSession {
  id            String    @id @default(cuid())
  monitorId     String
  monitoriaId   String
  institutionId String
  socketId      String?
  isOnline      Boolean   @default(true)
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  monitor     User        @relation("MonitorSessionsByUser", fields: [monitorId], references: [id], onDelete: Cascade)
  monitoria   Monitoria   @relation(fields: [monitoriaId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([monitorId])
  @@index([monitoriaId])
  @@index([institutionId, isOnline])
  @@index([monitoriaId, isOnline])
}
